# Entorno de PlatformIO
.pio/
.vscode/
*.bin
*.elf

# Archivos auto-generados de ESP-IDF
sdkconfig
sdkconfig.old
# NO ignorar sdkconfig.defaults (es la base para otros desarrolladores)
!sdkconfig.defaults
# Ignorar archivos temporales de compilación de PlatformIO por entorno
sdkconfig.*
!sdkconfig.defaults

# Compilación y Herramientas
build/
managed_components/
compile_commands.json
.venv/
.python-version
__pycache__/
*.pyc

# Archivos temporales de Sistemas Operativos
.DS_Store
Thumbs.db

